# Environment Variables Template
# Copy this file to .env and fill in your values

# OpenRouter API Key
# Get yours at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# TMDb API Key
# Get yours at: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# GitHub OAuth (for Supabase authentication)
# Get these from: https://github.com/settings/developers
# Then configure in Supabase Dashboard > Auth > Providers > GitHub
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Supabase Personal Access Token (for Management API)
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_PAT=your_supabase_pat_here
